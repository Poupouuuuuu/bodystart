# Shopify Storefront API
# Remplace par tes vraies valeurs (Admin Shopify > Paramètres > Apps > Développer des apps)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=ton-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=ton_token_storefront

# Shopify Admin API (requis pour Inventory/Click & Collect)
SHOPIFY_ADMIN_API_ACCESS_TOKEN=ton_token_admin

# URL de ton site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (envoi d'emails — /api/contact + /api/newsletter)
RESEND_API_KEY=re_xxx
CONTACT_EMAIL_TO=contact@bodystart.com
RESEND_AUDIENCE_ID=xxx                    # Audience Resend pour la newsletter (optionnel)

# Upstash Redis (rate limiting — /api/contact, /api/inventory)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Stripe (coaching — paiements + abonnements)
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
